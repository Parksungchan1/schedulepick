<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="30dp">

        <!-- ── 상단 바 ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/layout_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_logo"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="SCHEDULE\nPICK"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="1dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_friends"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="친구"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_mypage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="마이페이지"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp">

                    <ImageView
                        android:id="@+id/iv_profile"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_profile_circle"
                        android:src="@drawable/ic_profile_default"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_notification_dot"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp"
                        android:textStyle="bold"/>
                </FrameLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- ── 히어로 배너 (보라색 카드) ── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="156dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_home_purple_card"
            android:clipChildren="false">

            <!-- 타이틀 (좌상단) -->

            <!-- 지도 핀 (좌하단) -->

            <!-- 흰색 내부 카드 (우측 중앙) -->

            <!-- horizontal_bias: 0.0=완전왼쪽 ~ 1.0=완전오른쪽, vertical_bias: 0.0=완전위 ~ 1.0=완전아래 -->

            <TextView
                android:id="@+id/tv_hero_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="일정을 빠르고 간편하게"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_white_card"
                app:layout_constraintHorizontal_bias="3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.1" />

            <ImageView
                android:id="@+id/iv_map_pin"
                android:layout_width="89dp"
                android:layout_height="93dp"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="20dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_map_pin"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:id="@+id/iv_white_card"
                android:layout_width="216dp"
                android:layout_height="102dp"
                android:src="@drawable/rectangle_3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.6"/>

            <!-- 버튼 2개 (흰 카드 정중앙) -->
            <LinearLayout
                android:id="@+id/layout_buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="@id/iv_white_card"
                app:layout_constraintBottom_toBottomOf="@id/iv_white_card"
                app:layout_constraintStart_toStartOf="@id/iv_white_card"
                app:layout_constraintEnd_toEndOf="@id/iv_white_card">

                <TextView
                    android:id="@+id/btn_view_schedule"
                    android:layout_width="168dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_pill_button"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="내 일정 보기"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/btn_create_group"
                    android:layout_width="168dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_pill_button"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="그룹 만들기"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── 나의 그룹 보기 (보라 외부 + 흰색 내부) ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_group_purple"
            android:padding="11dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_group_white"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나의 그룹 보기"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_my_groups"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <ImageView
                    android:id="@+id/iv_expand"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#827EFF"/>
            </LinearLayout>
        </FrameLayout>

        <!-- ── 나의 일정 (흰색 카드) ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나의 일정"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_my_schedules"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
