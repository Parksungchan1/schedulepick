<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="30dp">

        <!-- ── 상단 바: 로고 + 알림 ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="24dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_logo"
                android:scaleType="fitCenter"
                android:contentDescription="로고"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/tv_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCHEDULE\nPICK"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                android:layout_toEndOf="@id/iv_logo"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"/>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageView
                    android:id="@+id/iv_notification"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_notifications"
                    android:contentDescription="알림"/>


            </FrameLayout>

        </RelativeLayout>

        <!-- ── 본문: 좌측 + 구분선 + 우측 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ═══ 좌측 컬럼 ═══ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- 프로필 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="13dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <!-- 프로필 사진 (원형) -->
                        <ImageView
                            android:id="@+id/iv_profile"
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:src="@drawable/ic_default_profile"
                            android:background="@drawable/bg_profile_circle"
                            android:scaleType="centerCrop"
                            android:contentDescription="프로필 사진"
                            android:layout_marginBottom="8dp"/>

                        <!-- 이름 -->
                        <TextView
                            android:id="@+id/tv_my_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:textColor="#535353"
                            android:layout_marginBottom="6dp"/>

                        <!-- @ID 태그 -->
                        <TextView
                            android:id="@+id/tv_my_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_id_tag"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:layout_marginBottom="10dp"/>

                        <!-- 프로필 수정하기 버튼 -->
                        <TextView
                            android:id="@+id/tv_edit_profile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="프로필 수정하기"
                            android:textSize="12sp"
                            android:textColor="#5A5A5A"
                            android:padding="4dp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 나의 통계 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="13dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="나의 통계"
                            android:textSize="15sp"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"/>

                        <!-- 참여 그룹 수 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="참여 그룹 수"
                                android:textSize="13sp"
                                android:textColor="#000000"/>
                            <TextView
                                android:id="@+id/tv_group_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="14sp"
                                android:textColor="#000000"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- 친구 수 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="친구 수"
                                android:textSize="13sp"
                                android:textColor="#000000"/>
                            <TextView
                                android:id="@+id/tv_friend_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="14sp"
                                android:textColor="#000000"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- 이달의 일정 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="이달의 일정"
                                android:textSize="13sp"
                                android:textColor="#000000"/>
                            <TextView
                                android:id="@+id/tv_schedule_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="14sp"
                                android:textColor="#000000"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 친구 목록 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="13dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="친구 목록"
                            android:textSize="16sp"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_mini_friends"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ─ 세로 구분선 ─ -->
            <View
                android:layout_width="5dp"
                android:layout_height="match_parent"
                android:background="#D9D9D9"
                android:layout_marginHorizontal="8dp"/>

            <!-- ═══ 우측 컬럼 ═══ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical">

                <!-- 기본 정보 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="13dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="기본 정보"
                            android:textSize="15sp"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>

                        <!-- 이름 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="이름"
                            android:textSize="13sp"
                            android:textColor="#383838"
                            android:layout_marginBottom="2dp"/>
                        <TextView
                            android:id="@+id/tv_info_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="#000000"
                            android:layout_marginBottom="10dp"/>

                        <!-- 이메일 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="이메일"
                            android:textSize="13sp"
                            android:textColor="#383838"
                            android:layout_marginBottom="2dp"/>
                        <TextView
                            android:id="@+id/tv_info_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="#000000"
                            android:layout_marginBottom="10dp"/>

                        <!-- 기본 주소지 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="기본 주소지"
                            android:textSize="13sp"
                            android:textColor="#383838"
                            android:layout_marginBottom="2dp"/>
                        <TextView
                            android:id="@+id/tv_info_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="#000000"
                            android:layout_marginBottom="10dp"/>

                        <!-- 소속 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="소속"
                            android:textSize="13sp"
                            android:textColor="#383838"
                            android:layout_marginBottom="2dp"/>
                        <TextView
                            android:id="@+id/tv_info_org"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="#000000"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 그룹 목록 카드 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="13dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="그룹 목록"
                            android:textSize="15sp"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_group_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
