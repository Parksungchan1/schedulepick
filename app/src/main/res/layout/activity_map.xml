<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 상단 바 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_left"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="뒤로"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="약속 장소 찾기"
            android:textSize="17sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_centerInParent="true"/>

    </RelativeLayout>

    <!-- 스크롤 영역 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 출발지 섹션 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="출발지 설정"
                        android:textSize="15sp"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="기본 주소지가 입력되어 있습니다. 클릭해서 수정할 수 있어요."
                        android:textSize="11sp"
                        android:textColor="#A2A2A2"
                        android:layout_marginBottom="12dp"/>

                    <!-- 멤버 위치 행 (Java에서 동적 추가) -->
                    <LinearLayout
                        android:id="@+id/layout_members"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 버튼 2개 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/btn_find_center"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="중간지점 찾기"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_pill_button"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btn_direct_input"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="직접 입력"
                    android:textSize="14sp"
                    android:textColor="#827EFF"
                    android:gravity="center"
                    android:background="@drawable/bg_schedule_group_pill"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- 직접 입력 필드 (기본 숨김) -->
            <LinearLayout
                android:id="@+id/layout_direct_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/et_direct_search"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="장소명 또는 주소 입력"
                    android:textSize="13sp"
                    android:background="@drawable/bg_search_bar"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:inputType="text"/>

                <TextView
                    android:id="@+id/btn_direct_search"
                    android:layout_width="60dp"
                    android:layout_height="44dp"
                    android:text="검색"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_today_circle"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- 지도 + 중간지점 정보 (검색 후 표시) -->
            <LinearLayout
                android:id="@+id/layout_map_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/fl_map_container"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="#E0E0E0"/>

                <TextView
                    android:id="@+id/tv_center_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="12sp"
                    android:textColor="#535353"/>

            </LinearLayout>

            <!-- 주변 장소 목록 -->
            <LinearLayout
                android:id="@+id/layout_cafes_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="주변 장소 (선택)"
                    android:textSize="14sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="장소를 선택한 뒤 하단 완료 버튼을 눌러주세요."
                    android:textSize="11sp"
                    android:textColor="#A2A2A2"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cafes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 완료 버튼 -->
    <TextView
        android:id="@+id/btn_map_complete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="완료"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_pill_button"
        android:layout_margin="16dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
