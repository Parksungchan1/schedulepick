<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingBottom="30dp"
    android:background="#FFFFFF">

    <!-- 핸들 바 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="#E0E0E0"/>

    <!-- 제목 + 닫기 버튼 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tv_detail_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/btn_detail_close"
            android:layout_centerVertical="true"
            android:textSize="20sp"
            android:textColor="#000000"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btn_detail_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#888888"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

    </RelativeLayout>

    <!-- 날짜 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:text="날짜"
            android:textSize="12sp"
            android:textColor="#A2A2A2"/>

        <TextView
            android:id="@+id/tv_detail_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#000000"/>
    </LinearLayout>

    <!-- 카테고리 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:text="카테고리"
            android:textSize="12sp"
            android:textColor="#A2A2A2"/>

        <TextView
            android:id="@+id/tv_detail_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#827EFF"/>
    </LinearLayout>

    <!-- 장소 -->
    <LinearLayout
        android:id="@+id/layout_detail_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:text="장소"
            android:textSize="12sp"
            android:textColor="#A2A2A2"/>

        <TextView
            android:id="@+id/tv_detail_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#000000"/>
    </LinearLayout>

    <!-- 참여자 -->
    <LinearLayout
        android:id="@+id/layout_detail_participants"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:text="참여자"
            android:textSize="12sp"
            android:textColor="#A2A2A2"/>

        <TextView
            android:id="@+id/tv_detail_participants"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#000000"/>
    </LinearLayout>

</LinearLayout>
