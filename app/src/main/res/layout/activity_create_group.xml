<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── 상단 바 ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="20dp"
            android:background="#F5F5F5">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="24dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_logo"
                android:scaleType="fitCenter"
                android:contentDescription="로고"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/tv_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCHEDULE\nPICK"
                android:textSize="16sp"
                android:textColor="#000000"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                android:layout_toEndOf="@id/iv_logo"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"/>

        </RelativeLayout>

        <!-- ── 메인 카드 ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="17dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 제목 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="새로운 그룹 생성"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <!-- ── 그룹 사진 섹션 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:layout_marginBottom="20dp">

                    <!-- 사진 미리보기 영역 -->
                    <FrameLayout
                        android:id="@+id/fl_photo_area"
                        android:layout_width="109dp"
                        android:layout_height="106dp"
                        android:background="@drawable/bg_group_photo_area"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/iv_group_photo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:contentDescription="그룹 사진"/>

                        <TextView
                            android:id="@+id/tv_photo_hint"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="JPG / PNG\n형식의 파일만\n업로드가 가능합니다"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </FrameLayout>

                    <!-- 라벨 + 버튼 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="그룹 사진"
                            android:textSize="11sp"
                            android:textColor="#000000"
                            android:layout_marginBottom="10dp"/>

                        <TextView
                            android:id="@+id/btn_load_photo"
                            android:layout_width="54dp"
                            android:layout_height="33dp"
                            android:text="사진\n불러오기"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="@drawable/bg_group_photo_btn_purple"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/btn_delete_photo"
                            android:layout_width="53dp"
                            android:layout_height="33dp"
                            android:text="사진\n삭제하기"
                            android:textSize="10sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="@drawable/bg_group_photo_btn_gray"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── 그룹 이름 ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="그룹 이름"
                    android:textSize="11sp"
                    android:textColor="#000000"/>

                <EditText
                    android:id="@+id/et_group_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="그룹의 이름을 입력해주세요"
                    android:textColorHint="#7C7C7C"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:inputType="text"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9"
                    android:layout_marginBottom="14dp"/>

                <!-- ── 대표자 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="대표자"
                        android:textSize="11sp"
                        android:textColor="#000000"/>

                    <!-- Firebase에서 현재 사용자 이름 로드 -->
                    <TextView
                        android:id="@+id/tv_representative"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#535353"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"/>

                <!-- ── 소속 ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="소속"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:letterSpacing="0.08"/>

                <EditText
                    android:id="@+id/et_affiliation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="그룹의 소속을 입력해주세요 ex)백석대학교"
                    android:textColorHint="#7C7C7C"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:inputType="text"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9"
                    android:layout_marginBottom="14dp"/>

                <!-- ── 기본 거점 주소 ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기본 거점 주소"
                    android:textSize="11sp"
                    android:textColor="#000000"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/et_base_address"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="기본 모임장소를 설정해주세요"
                        android:textColorHint="#7C7C7C"
                        android:textSize="11sp"
                        android:textColor="#000000"
                        android:background="@null"
                        android:paddingVertical="8dp"
                        android:inputType="text"/>

                    <TextView
                        android:id="@+id/btn_search_address"
                        android:layout_width="45dp"
                        android:layout_height="25dp"
                        android:text="검색"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_small_button"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D9D9D9"
                    android:layout_marginBottom="18dp"/>

                <!-- ── 그룹인원 ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="그룹인원"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="18dp">

                    <LinearLayout
                        android:id="@+id/layout_members"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- 멤버 추가 버튼 (Java에서 멤버 항목은 이 앞에 동적 삽입) -->
                        <LinearLayout
                            android:id="@+id/btn_add_member"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_add_member_circle">

                                <ImageView
                                    android:layout_width="23dp"
                                    android:layout_height="22dp"
                                    android:src="@drawable/ic_add"
                                    android:layout_gravity="center"
                                    android:contentDescription="멤버 추가"/>

                            </FrameLayout>

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- ── 그룹 분류 ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="그룹 분류"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <!-- 분류 칩 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/chip_company"
                        android:layout_width="52dp"
                        android:layout_height="37dp"
                        android:text="회사"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:background="@drawable/bg_group_category_chip"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_school"
                        android:layout_width="54dp"
                        android:layout_height="37dp"
                        android:text="학교"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:background="@drawable/bg_group_category_chip"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_team"
                        android:layout_width="56dp"
                        android:layout_height="37dp"
                        android:text="팀모임"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:background="@drawable/bg_group_category_chip"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_other"
                        android:layout_width="52dp"
                        android:layout_height="37dp"
                        android:text="기타"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:background="@drawable/bg_group_category_chip"/>

                </LinearLayout>

                <!-- 그룹 색상 선택 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/color_pink"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_circle_dot"
                        android:backgroundTint="#FFA6A6"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <View
                        android:id="@+id/color_purple_dot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_circle_dot"
                        android:backgroundTint="#E08AFF"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <View
                        android:id="@+id/color_green"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_circle_dot"
                        android:backgroundTint="#54C05A"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <View
                        android:id="@+id/color_yellow"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_circle_dot"
                        android:backgroundTint="#FFD151"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <View
                        android:id="@+id/color_blue"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/bg_circle_dot"
                        android:backgroundTint="#4FA1FF"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── 그룹 생성하기 버튼 ── -->
        <TextView
            android:id="@+id/btn_create_group"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:text="그룹 생성하기"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_login_button"/>

    </LinearLayout>

</ScrollView>
